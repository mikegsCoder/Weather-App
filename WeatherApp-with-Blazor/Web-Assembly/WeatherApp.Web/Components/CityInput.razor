<div class="h-56 flex flex-col items-center justify-center ">
    <EditForm FormName="WeatherForm"
              OnSubmit="SendData"
              Model="@City"
              class="text-black grid gap-5">

        <InputText @bind-Value="City"
                   id="cityInput"
                   class="text-2xl bg-transparent outline-none border-b-2 w-96 h-12 pl-2 pr-2 capitalize"
                   placeholder="Enter Your City Name"
                   oninput="clearBody()" />

        <button type="submit"
                id="btn"
                class="bn3 text-2xl">
            Search
        </button>

    </EditForm>
</div>
