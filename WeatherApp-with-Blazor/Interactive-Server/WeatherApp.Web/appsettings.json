{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "App": {
    "Title": "WeatherApp",
    "Urls": {
      "IconUrl": "img/icon.ico",
      "StylesUrl": "css/styles.css",
      "ComponentsStylesUrl": "WeatherApp.Web.styles.css",
      "FontAwesomeUrl": "https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
    },
    "Js": {
      "TailwindUrl": "https://cdn.tailwindcss.com",
      "SiteJsUrl": "js/site.js",
      "BlazorJsUrl": "_framework/blazor.web.js"
    },
    "Header": {
      "LogoUrl": "img/logo.gif",
      "BlazorUrl": "https://dotnet.microsoft.com/en-us/apps/aspnet/web-apps/blazor",
      "Title": "Weather App with Blazor"
    },
    "Footer": {
      "DataProviderUrl": "https://openweathermap.org/",
      "SourceCodeUrl": "https://github.com/mikegsCoder/Weather-App/"
    },
    "ApiConstants": {
      "ApiKey": "YourApiKey",
      "BaseUrl": "https://api.openweathermap.org/data/2.5/"
    }
  }
}
